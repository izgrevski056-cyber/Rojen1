rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /accounts/{username} {
      allow read, write: if true;

      match /days/{dayId} {
        allow read, write: if true;
      }
    }

    // Legacy path — read-only fallback
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
      match /days/{dayId} {
        allow read: if true;
        allow write: if false;
      }
    }
  }
}
